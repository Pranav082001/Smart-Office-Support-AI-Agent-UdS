# ── Groq API ──────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Available free models on Groq:
# llama-3.1-8b-instant   (fastest, good for classification)
# llama-3.3-70b-versatile (more accurate, slightly slower)
# llama3-8b-8192
# mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# ── Email API ─────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json

# ── Notion API ───────────────────────────────────
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Google Calendar API ──────────────────────────
CALENDAR_CREDENTIALS_PATH=credentials/calendar_credentials.json
CALENDAR_TOKEN_PATH=credentials/calendar_token.json

# ── Company Profile ───────────────────────────────
COMPANY_PROFILE_PATH=data/company_profile.json
